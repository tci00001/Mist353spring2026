@page
@model SportsStore_Spr2026.Pages.Products.ProductDetailsModel
@{
}





<div class="row justify-content-center">
    
    
    
    <div class="card col-md-8 p-3">
        
        <div class="text-center">
            <img class="card-img-top" src="~/images/@Model.product." style="Width:400px"/>

            



        </div>
        
        
        <H1 class="card-title text-center">@Model.product.Name</H1>
        
        <p class="card-text text-center">
            
            @Model.product.Description
            
        </p>
        
        <p class="card-text text-center">
            
            Price: $@Model.product.Price
        </p>
        


        <div>

            <a asp-page="/Products/UpdateProduct" asp-route-id="Model.product.ProductID"
            class="btn btn-primary">Update Product Information</a>


        </div>
        


    </div>
    
    
    
    
    
    
    

</div>